# Claude Runner — lightweight SSH target for Paperclip remote agent execution.
# Hosts Claude Code, Codex, OpenCode CLIs and any MCP servers that Derek installs.
# Paperclip server reaches this via the runner-net Docker network (SSH on port 22).
# Persistent state (MCPs, OAuth tokens, history) lives in /home/runner via the
# claude-runner-home volume.

FROM node:22-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      openssh-server \
      ca-certificates \
      curl \
      git \
      jq \
      gnupg \
      python3 \
      python3-pip \
      sudo \
      tini \
      libnss3 \
      libnspr4 \
      libatk1.0-0 \
      libatk-bridge2.0-0 \
      libcups2 \
      libdrm2 \
      libxkbcommon0 \
      libxcomposite1 \
      libxdamage1 \
      libxfixes3 \
      libxrandr2 \
      libgbm1 \
      libpango-1.0-0 \
      libcairo2 \
      libasound2 \
      fonts-liberation \
 && rm -rf /var/lib/apt/lists/* \
 && mkdir -p /var/run/sshd

# Pin a known-working set of agent CLIs. Bump versions deliberately via PR.
RUN npm install --global \
      @anthropic-ai/claude-code@latest \
      @openai/codex@latest \
      opencode-ai

# Create unprivileged runner user. UID 1001 to keep it distinct from the node
# image's default `node` user (UID 1000) so volume permissions are obvious.
RUN groupadd --gid 1001 runner \
 && useradd --uid 1001 --gid runner --create-home --shell /bin/bash runner \
 && passwd -d runner

# SSH hardening: no password auth, no root login. Public key only.
RUN sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config \
 && sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config \
 && sed -i 's/^#\?ChallengeResponseAuthentication.*/ChallengeResponseAuthentication no/' /etc/ssh/sshd_config \
 && sed -i 's/^#\?UsePAM.*/UsePAM no/' /etc/ssh/sshd_config \
 && sed -i 's/^#\?PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config \
 && sed -i 's/^#\?PermitEmptyPasswords.*/PermitEmptyPasswords no/' /etc/ssh/sshd_config \
 && echo "AcceptEnv PAPERCLIP_* CLAUDE_* CODEX_* OPENCODE_*" >> /etc/ssh/sshd_config

# Make sure runner's home is owned correctly at first boot if the volume is empty.
COPY docker/claude-runner/entrypoint.sh /usr/local/bin/claude-runner-entrypoint.sh
RUN chmod +x /usr/local/bin/claude-runner-entrypoint.sh

EXPOSE 22

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/claude-runner-entrypoint.sh"]
CMD ["/usr/sbin/sshd", "-D", "-e"]
