{
  "name": "@m42/plugin-agent-outputs",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Unified catalog of documents, comments, attachments and thread interactions generated by AI agents across all company issues.",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @paperclipai/plugin-sdk ensure-build-deps",
    "build": "node ./esbuild.config.mjs",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4178",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk ensure-build-deps && tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "agent-outputs",
    "catalog"
  ],
  "author": "M42",
  "license": "MIT",
  "devDependencies": {
    "@paperclipai/plugin-sdk": "workspace:*",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.27.3",
    "react-dom": "^19.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
